    "lint": "eslint src",
    "staged": "npm run fix-style && npm run typecheck && npm run lint"
  },
  "peerDependencies": {
    "@devexperts/remote-data-ts": "^2.1.1",
    "@rinn7e/tea-cup-prelude": "^1.0.0",
    "fp-ts": "^2.16.11",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-tea-cup": "^5.1.1",
    "tea-cup-fp": "^1.1.1"
  },
  "devDependencies": {
    "@devexperts/remote-data-ts": "^2.1.1",
    "@eslint/js": "^9.29.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@rinn7e/tea-cup-prelude": "github:rinn7e/tea-cup-prelude#096c9d7eec9132cfee035fc27818dba96e48f2e9",
    "eslint": "^9.29.0",
